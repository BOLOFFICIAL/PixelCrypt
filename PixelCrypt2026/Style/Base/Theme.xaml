<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Brush x:Key="Accent">#B22222</Brush>
    
    <Brush x:Key="Background">#1E1E1E</Brush>
    <Brush x:Key="Background1">#2D2D2D</Brush>
    <Brush x:Key="Background2">#3C3C3C</Brush>
    <Brush x:Key="Background3">#4B4B4B</Brush>
    <Brush x:Key="Background4">#5A5A5A</Brush>
    <Brush x:Key="Background5">#696969</Brush>
    <Brush x:Key="Foreground">White</Brush>

    <Brush x:Key="StatusNone">#808080</Brush>
    <Brush x:Key="StatusSuccess">#388E3C</Brush>
    <Brush x:Key="StatusPending">#C27D0A</Brush>
    <Brush x:Key="StatusInProgress">#3173A5</Brush>
    <Brush x:Key="StatusFailed">#B52323</Brush>
    <Brush x:Key="StatusCancelled">#736060</Brush>

    <Color x:Key="NotificationBaseColor">#FF1E1E1E</Color>
    <Color x:Key="NotificationSuccessColor">#228B22</Color>
    <Color x:Key="NotificationErrorColor">#A52A2A</Color>
    <Color x:Key="NotificationQuestionColor">#FFA500</Color>

</ResourceDictionary>