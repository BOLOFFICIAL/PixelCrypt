<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Brush x:Key="Accent">#D94A4A</Brush>

    <Brush x:Key="Background">#211C1C</Brush>
    <Brush x:Key="Background1">#2D2626</Brush>
    <Brush x:Key="Background2">#3B3232</Brush>
    <Brush x:Key="Background3">#493E3E</Brush>
    <Brush x:Key="Background4">#5A4C4C</Brush>
    <Brush x:Key="Background5">#705E5E</Brush>

    <Brush x:Key="Foreground">#EDE8E8</Brush>

    <Brush x:Key="ImageChipBackground">#3B3232</Brush>
    <Brush x:Key="ImageChipForeground">#EDE8E8</Brush>

    <Brush x:Key="ImageChipSelectedBackground">#5F1E1E</Brush>
    <Brush x:Key="ImageChipSelectedForeground">#F1C3C3</Brush>

    <Brush x:Key="ButtonBackground">#D94A4A</Brush>
    <Brush x:Key="ButtonForeground">White</Brush>

    <Brush x:Key="StatusNone">#705E5E</Brush>
    <Brush x:Key="StatusSuccess">#2D7D46</Brush>
    <Brush x:Key="StatusPending">#D9A343</Brush>
    <Brush x:Key="StatusInProgress">#A53131</Brush>
    <Brush x:Key="StatusFailed">#D93B3B</Brush>
    <Brush x:Key="StatusCancelled">#7A6262</Brush>

    <Color x:Key="NotificationBaseColor">#2D2626</Color>
    <Color x:Key="NotificationSuccessColor">#2D7D46</Color>
    <Color x:Key="NotificationErrorColor">#D93B3B</Color>
    <Color x:Key="NotificationQuestionColor">#D9A343</Color>

</ResourceDictionary>