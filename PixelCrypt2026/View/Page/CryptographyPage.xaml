<Page x:Class="PixelCrypt2026.View.Page.CryptographyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PixelCrypt2026.View.Page" 
      xmlns:controls="clr-namespace:PixelCrypt2026.View.UserControl"
      mc:Ignorable="d" 
      d:DesignHeight="450" 
      d:DesignWidth="800"
      Title="CryptographyPage">

    <controls:BasePageLayout Title="{Binding Title}"
                             BackCommand="{Binding BackCommand}">
        <controls:BasePageLayout.PageContent>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{Binding ProgressHeight}"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <controls:ProgressPanel DataContext="{Binding Progress}"/>
                    </Grid>

                    <Grid Grid.Row="1">
                        <controls:ImageList DataContext="{Binding ImageList}"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <controls:TaskControl DataContext="{Binding TaskControl}"/>
                    </Grid>
                </Grid>

                <Grid Grid.Column="1">
                    <Border Grid.Column="1"
                            Margin="20,0,0,0"
                            Background="#202020"
                            CornerRadius="12">

                        <Image Stretch="Uniform"
                               Source="{Binding ImageList.SelectedImage.ImageFile.FilePath}"/>
                    </Border>
                </Grid>

            </Grid>
        </controls:BasePageLayout.PageContent>
    </controls:BasePageLayout>
</Page>
