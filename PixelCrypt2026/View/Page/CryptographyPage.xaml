<Page x:Class="PixelCrypt2026.View.Page.CryptographyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PixelCrypt2026.View.Page" 
      xmlns:controls="clr-namespace:PixelCrypt2026.View.UserControl"
      mc:Ignorable="d"
      Title="CryptographyPage">

    <controls:BasePageLayout Title="{Binding Title}"
                             BackCommand="{Binding BackCommand}">
        <controls:BasePageLayout.PageContent>
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{Binding ProgressHeight}"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="{Binding SettingsHeight}"/>
                        <RowDefinition Height="{Binding TaskControlHeight}"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Margin="0,0,0,10">
                        <controls:ProgressPanel DataContext="{Binding Progress}"/>
                    </Grid>

                    <Grid Grid.Row="1">
                        <controls:ImageList DataContext="{Binding ImageList}"/>
                    </Grid>

                    <Grid Grid.Row="2"
                          Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0"
                                  Margin="0,0,5,0">
                                <Label Content="Масштаб"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center"
                                       FontSize="20"
                                       Foreground="{StaticResource Foreground}"/>
                            </Grid>

                            <Grid Grid.Column="1">
                                <ComboBox ItemsSource="{Binding ComboBoxItem}"
                                          SelectedValue="{Binding ComboBoxValue}"/>
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="1"
                              Margin="0,10,0,0">
                            <controls:PasswordBox DataContext="{Binding PasswordBox}"/>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="3"
                          Margin="0,10,0,0">
                        <controls:TaskControl DataContext="{Binding TaskControl}"/>
                    </Grid>
                </Grid>

                <Grid Grid.Column="1">
                    <Border Grid.Column="1"
                            Margin="10,0,0,0"
                            Background="{StaticResource Background1}"
                            CornerRadius="15">

                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="0"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Border Background="{StaticResource Background2}"
                                        CornerRadius="10"
                                        Padding="10">
                                    <Image Stretch="Uniform"
                                           Source="{Binding ImageList.SelectedImage.ImageFile.FilePath}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
        </controls:BasePageLayout.PageContent>
    </controls:BasePageLayout>
</Page>
