<UserControl x:Class="PixelCrypt2026.View.UserControl.ToolCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PixelCrypt2026.View.UserControl"
             mc:Ignorable="d" 
             d:DesignHeight="150" 
             d:DesignWidth="200">
    
    <Border CornerRadius="10"
            Margin="10"
            BorderThickness="1"
            BorderBrush="Aqua">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Label Content="{Binding Title}"/>
            </Grid>

            <Grid Grid.Row="1">
                <Label Content="{Binding Description}"/>
            </Grid>

            <Grid Grid.Row="2">
                <Button Content="Выбрать"
                        CommandParameter="{Binding ToolCardParameter}"
                        Command="{Binding ToolCardCommand}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
