<UserControl x:Class="PixelCrypt2026.View.UserControl.ImageChip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PixelCrypt2026.View.UserControl">

    <Grid DataContext="{Binding Image, RelativeSource={RelativeSource AncestorType=local:ImageChip}}"
          Margin="0,5">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding StatusWidth}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,5,0"
                Padding="10,5"
                VerticalAlignment="Top"
                BorderThickness="1"
                BorderBrush="Black"
                CornerRadius="10">

            <TextBlock Text="{Binding StatusValue}"/>

        </Border>

        <Border Grid.Column="1"
                BorderThickness="1"
                BorderBrush="{Binding BorderBrush}"
                Background="{Binding Background}"
                CornerRadius="10">

            <TextBlock Text="{Binding ImageFile.FileName}"
                       Foreground="{Binding Foreground}"
                       VerticalAlignment="Center"
                       Padding="10,5"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap">
                <TextBlock.ToolTip>
                    <ToolTip BorderThickness="0"
                             Background="Transparent">
                        <Border Background="White" 
                                BorderBrush="Black" 
                                BorderThickness="1" 
                                CornerRadius="5"
                                Padding="10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" 
                                            Margin="0,0,0,5">
                                    <TextBlock Text="{Binding ImageFile.FileName}" 
                                               FontWeight="Bold" 
                                               FontSize="15"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" 
                                            Margin="0,0,0,5">
                                    <StackPanel>
                                        <TextBlock Text="File Size" 
                                                   FontSize="10"
                                                   FontWeight="Medium"/>
                                        <TextBlock Text="{Binding ImageFile.FileSizeFormatted}" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="13"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" 
                                            Margin="0,0,0,5">
                                    <StackPanel>
                                        <TextBlock Text="Resolution" 
                                                   FontSize="10"
                                                   FontWeight="Medium"/>
                                        <TextBlock Text="{Binding ImageFile.ImageResolution}" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="13"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <StackPanel>
                                        <TextBlock Text="Location" 
                                                   FontSize="10"
                                                   FontWeight="Medium"/>
                                        <TextBlock Text="{Binding ImageFile.FilePath}" 
                                                   TextWrapping="Wrap" 
                                                   MaxWidth="500"
                                                   FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ToolTip>
                </TextBlock.ToolTip>
            </TextBlock>

        </Border>

    </Grid>

</UserControl>