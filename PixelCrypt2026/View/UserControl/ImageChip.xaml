<UserControl x:Class="PixelCrypt2026.View.UserControl.ImageChip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PixelCrypt2026.View.UserControl">

    <Grid DataContext="{Binding Image, RelativeSource={RelativeSource AncestorType=local:ImageChip}}"
          Margin="0,5">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding StatusWidth}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,5,0"
                Padding="10,5"
                VerticalAlignment="Top"
                BorderThickness="1"
                BorderBrush="Black"
                CornerRadius="10">

            <TextBlock Text="{Binding StatusValue}"/>

        </Border>

        <Border Grid.Column="1"
                BorderThickness="1"
                BorderBrush="{Binding BorderBrush}"
                Background="{Binding Background}"
                CornerRadius="10">

            <TextBlock Text="{Binding ImageFile.FileName}"
                       Foreground="{Binding Foreground}"
                       VerticalAlignment="Center"
                       Padding="10,5"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"/>

        </Border>

    </Grid>

</UserControl>