<UserControl x:Class="PixelCrypt2026.View.UserControl.PasswordBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PixelCrypt2026.View.UserControl" 
             xmlns:base="clr-namespace:PixelCrypt2026.View.UserControl.Base"
             xmlns:fa="http://schemas.fontawesome.com/icons/" 
             mc:Ignorable="d">
    <Border BorderThickness="1"
            BorderBrush="Black"
            CornerRadius="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding HideWidth}"/>
                    <ColumnDefinition Width="{Binding VisibleWidth}"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <base:BindablePasswordBox Password="{Binding Path=Password,UpdateSourceTrigger=PropertyChanged}"
                                      FontSize="15"
                                      Margin="0"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      Padding="10,0"/>
                </Grid>

                <Grid Grid.Column="1">
                    <TextBox Text="{Binding Password,UpdateSourceTrigger=PropertyChanged}"
                     BorderThickness="0"
                     Background="Transparent"
                     Padding="10,0"
                             FontWeight="Bold"
                     Margin="0"
                     FontSize="15"
                     HorizontalAlignment="Stretch"
                     HorizontalContentAlignment="Center"
                     VerticalAlignment="Center"/>
                </Grid>
            </Grid>

            <Grid Grid.Column="1">
                <Button Command="{Binding ToggleVisibilityCommand}"
                Padding="5"
                Background="Transparent"
                Margin="0">
                    <fa:ImageAwesome Icon="{Binding ToggleVisibilityIcon,UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{Binding Color3}"
                             Width="25"
                             Height="25"/>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
