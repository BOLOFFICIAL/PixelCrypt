<Window x:Class="PixelCrypt2026.View.Window.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PixelCrypt2026.View.Window" 
        xmlns:fa="http://schemas.fontawesome.com/icons/"
        mc:Ignorable="d"
        MinWidth="250"
        MaxWidth="300"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        MinHeight="300"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border BorderBrush="{StaticResource Foreground}"
            BorderThickness="2"
            CornerRadius="15">

        <Border.Background>
            <LinearGradientBrush StartPoint="0.5,0" 
                         EndPoint="0.5,1">
                <GradientStop Offset="0" 
                      Color="{Binding StatusColor}" />
                <GradientStop Offset="1" 
                      Color="{StaticResource NotificationBaseColor}" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Button Background="Transparent"
                    Padding="0"
                    Command="{Binding CloseCommand}"
                    HorizontalAlignment="Right">
                    <fa:ImageAwesome Icon="Regular_TimesCircle"
                                     Foreground="{StaticResource Foreground}"
                                     Width="20"
                                     Height="20">
                    </fa:ImageAwesome>
                </Button>
            </Grid>

            <Grid Grid.Row="1">
                <fa:ImageAwesome Icon="{Binding Icon}"
                             Width="90"
                             Height="90"
                             VerticalAlignment="Center">
                    <fa:ImageAwesome.Effect>
                        <BlurEffect Radius="5"/>
                    </fa:ImageAwesome.Effect>
                </fa:ImageAwesome>
            </Grid>

            <Grid Grid.Row="2"
                  Margin="10,0">
                <TextBlock Text="{Binding Title}"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource Foreground}"/>
            </Grid>

            <Grid Grid.Row="3"
                  Margin="10,20">
                <TextBlock Text="{Binding Content}"
                           FontSize="15"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource Foreground}"/>
            </Grid>

            <Grid Grid.Row="4">

            </Grid>
        </Grid>
    </Border>
</Window>